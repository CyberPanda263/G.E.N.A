# =========================================================
# 🔐 СЕКРЕТИ ТА КОНФІДЕНЦІЙНІ ДАНІ (КРИТИЧНО)
# =========================================================
# Блокуємо всі файли конфігурацій, що можуть містити реальні паролі та токени
.env
*.env
env.sh
secrets.sh
credentials.sh
private.key
*.pem

# Дозволяємо трекати лише демонстраційний шаблон конфігурації
!EXAMPLE.env

# =========================================================
# 💻 СИСТЕМНІ ФАЙЛИ ТА КЕШ ОПЕРАЦІЙНИХ СИСТЕМ
# =========================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.fuse_hidden
*.market
.directory

# =========================================================
# 🛠️ НАЛАШТУВАННЯ РЕДАКТОРІВ КОДУ ТА IDE
# =========================================================
# VS Code (ігноруємо локальні робочі простори та історію)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# JetBrains (IntelliJ, WebStorm, PyCharm тощо)
.idea/

# Тимчасові файли текстових редакторів
*.swp
*.swo
*~

# =========================================================
# 📊 ЛОГИ ТА ТИМЧАСОВІ ФАЙЛИ СКРИПТІВ
# =========================================================
*.log
logs/
tmp/
temp/